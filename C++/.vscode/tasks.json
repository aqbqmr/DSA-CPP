{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "C++: Compile Current File",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run_cpp_file.sh",
      "args": [
        "compile",
        "${file}"
      ],
      "group": "build",
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    },
    {
      "label": "C++: Run Current File",
      "type": "shell",
      "command": "${workspaceFolder}/scripts/run_cpp_file.sh",
      "args": [
        "run",
        "${file}"
      ],
      "group": {
        "kind": "build",
        "isDefault": true
      },
      "problemMatcher": [
        "$gcc"
      ],
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "clear": true
      }
    }
  ]
}
